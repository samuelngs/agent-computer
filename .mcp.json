{
  "mcpServers": {
    "apc": {
      "type": "stdio",
      "command": "target/release/apc-host",
      "args": [
        "--kernel", "guest/out/aarch64/vmlinuz",
        "--initrd", "guest/out/aarch64/initramfs",
        "--disk", "guest/out/aarch64/disk.img",
        "--mcp-stdio"
      ]
    }
  }
}
