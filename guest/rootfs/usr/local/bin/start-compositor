#!/bin/sh
PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin

kmsg() { echo "$1" > /dev/kmsg 2>/dev/null || true; }

kmsg "start-compositor: script started"

for i in $(seq 1 40); do
    [ -e /dev/dri/card0 ] && break
    sleep 0.25
done

if [ ! -e /dev/dri/card0 ]; then
    kmsg "start-compositor: no DRM device found"
    sleep 2
    exit 1
fi

APC_UID="$(id -u agent 2>/dev/null || echo 1000)"
APC_GID="$(id -g agent 2>/dev/null || echo 1000)"
XDG_RUNTIME_DIR="/run/user/$APC_UID"
mkdir -p "$XDG_RUNTIME_DIR"
chown "$APC_UID:$APC_GID" "$XDG_RUNTIME_DIR"
chmod 0700 "$XDG_RUNTIME_DIR"

APC_SCALE="$(sed -n 's/.*apc\.scale=\([0-9][0-9]*\).*/\1/p' /proc/cmdline 2>/dev/null)"
APC_SCALE="${APC_SCALE:-2}"
XCURSOR_SIZE="$((24 * APC_SCALE))"
DEBUG_SKIP_CLIENT_SURFACES=
if grep -qw 'apc.skip_client_surfaces=1' /proc/cmdline 2>/dev/null; then
    DEBUG_SKIP_CLIENT_SURFACES=APC_DEBUG_SKIP_CLIENT_SURFACES=1
fi

if [ ! -x /usr/local/bin/apc-compositor ]; then
    kmsg "start-compositor: apc-compositor not found"
    exit 1
fi

kmsg "start-compositor: launching apc-compositor (scale=$APC_SCALE)"
LOG=/tmp/apc-compositor.log
: > "$LOG"
chown "$APC_UID:$APC_GID" "$LOG" 2>/dev/null || true

setpriv \
    --reuid "$APC_UID" \
    --regid "$APC_GID" \
    --init-groups \
    env \
    PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin \
    HOME=/home/agent \
    XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" \
    WLR_BACKENDS=drm \
    WLR_RENDERER=gles2 \
    LIBSEAT_BACKEND=noop \
    SMITHAY_USE_LEGACY=1 \
    XCURSOR_THEME=Adwaita \
    XCURSOR_SIZE="$XCURSOR_SIZE" \
    APC_SCALE="$APC_SCALE" \
    APC_HOST_CURSOR=1 \
    APC_INPUT_DEBUG=1 \
    $DEBUG_SKIP_CLIENT_SURFACES \
    RUST_BACKTRACE=1 \
    RUST_LOG=info \
    /usr/local/bin/apc-compositor > "$LOG" 2>&1 &
COMPOSITOR_PID=$!

(
    tail -n +1 -f "$LOG" 2>/dev/null | while IFS= read -r line; do
        kmsg "compositor: $line"
    done
) &
TAIL_PID=$!

wait "$COMPOSITOR_PID"
STATUS=$?
kill "$TAIL_PID" 2>/dev/null || true
exit "$STATUS"
